DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=Africa/Algiers

DB_ENGINE=django.db.backends.mysql
DB_NAME=concours_nominative
DB_USER=concours_user
DB_PASSWORD=concours_password
DB_HOST=127.0.0.1
DB_PORT=3306

ANON_DB_ENGINE=django.db.backends.mysql
ANON_DB_NAME=concours_anonymization
ANON_DB_USER=anonymization_user
ANON_DB_PASSWORD=anonymization_password
ANON_DB_HOST=127.0.0.1
ANON_DB_PORT=3306

JWT_ACCESS_TOKEN_HOURS=8
JWT_REFRESH_TOKEN_HOURS=24

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_TIME_LIMIT=300

DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
